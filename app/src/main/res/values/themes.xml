<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Tema base SEM DayNight -->
    <style name="Theme.RQM" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Cor principal (azul marinho do logo) -->
        <item name="colorPrimary">@color/indica_navy</item>
        <item name="colorPrimaryVariant">@color/indica_navy_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Cor secundaria (azul aco) -->
        <item name="colorSecondary">@color/indica_steel</item>
        <item name="colorSecondaryVariant">@color/indica_steel</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Cor da barra de status -->
        <item name="android:statusBarColor">@color/indica_navy_dark</item>

        <!-- Fundo padrao claro -->
        <item name="android:colorBackground">@color/indica_ice</item>
        <item name="colorOnBackground">@color/indica_text</item>

        <!-- Outros ajustes -->
        <item name="android:navigationBarColor">@color/indica_navy</item>
    </style>

    <!-- Tema sem ActionBar -->
    <style name="Theme.RQM.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.RQM.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />
    <style name="Theme.RQM.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

</resources>
