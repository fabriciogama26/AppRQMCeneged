<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtTitulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sobre_titulo"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/indica_navy"
            android:gravity="center" />

        <TextView
            android:id="@+id/txtDescricao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/sobre_descricao"
            android:textSize="15sp"
            android:textColor="@color/indica_text" />

        <TextView
            android:id="@+id/txtEmpresa"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/sobre_empresa"
            android:textSize="14sp"
            android:textColor="@color/indica_text" />

        <TextView
            android:id="@+id/txtSite"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/sobre_site"
            android:textSize="14sp"
            android:textColor="@color/indica_navy"
            android:autoLink="web" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:background="@color/indica_field_stroke" />

        <TextView
            android:id="@+id/txtImeiTitulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/sobre_imei_titulo"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/indica_text" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutImeiCadastro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/hint_imei_contato"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusTopStart="12dp"
            app:boxStrokeColor="@color/indica_field_stroke"
            app:boxBackgroundColor="@color/indica_field_bg">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etImeiCadastro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:textColor="@color/indica_text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSalvarImei"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/btn_salvar_imei"
            android:textColor="@color/white"
            android:backgroundTint="@color/indica_navy"
            app:cornerRadius="14dp" />

    </LinearLayout>
</ScrollView>
