<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="14dp"
    app:cardElevation="1dp"
    app:strokeColor="@color/indica_steel"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/txtCodigoResumo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Codigo: 12345"
            android:textColor="@color/indica_text"
            android:textStyle="bold"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/txtDescricaoResumo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Descricao do material"
            android:textColor="@color/indica_text"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/txtQuantidadeResumo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Quantidade: 0"
            android:textColor="@color/indica_muted"
            android:textSize="12sp" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
